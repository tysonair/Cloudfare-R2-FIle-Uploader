# Cloudflare R2 配置示例
# 复制此文件为 .env 并填入你的实际配置

# R2 账户 ID
R2_ACCOUNT_ID=your_account_id_here

# R2 访问密钥 ID
R2_ACCESS_KEY_ID=your_access_key_id_here

# R2 访问密钥密文
R2_ACCESS_KEY_SECRET=your_access_key_secret_here

# R2 存储桶名称
R2_BUCKET_NAME=your_bucket_name_here

# R2 端点 URL (格式: https://<account_id>.r2.cloudflarestorage.com)
R2_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com

# R2 自定义域名 (可选，用于文件分享)
R2_CUSTOM_DOMAIN=your_custom_domain.com

# R2 公共域名 (可选，R2.dev 域名用于文件分享)
R2_PUBLIC_DOMAIN=your_bucket.r2.dev
